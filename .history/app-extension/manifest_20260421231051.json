{
  "manifest_version": 3,
  "name": "GuardianCore",
  "version": "0.6.0",
  "description": "Parental control with rules, groups, PIN protection, XP rewards, and AI content classification",
  "permissions": ["declarativeNetRequest", "declarativeNetRequestWithHostAccess", "webRequest", "webNavigation", "storage", "tabs", "downloads"],
  "host_permissions": ["<all_urls>"],
  "background": { 
    "service_worker": "background.js",
    "type": "module"
  },
  "action": { 
    "default_popup": "popup.html",
    "default_title": "GuardianCore"
  },
  "options_page": "options.html",
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content-script.js", "lens-bubble.js"],
    "run_at": "document_idle"
  }],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [{
    "resources": ["blocked.html", "blocked.js","crypto.js", "strings.js", "login.html", "child-options.html", "pin-lock.html", "test-enforcement.html"],
    "matches": ["<all_urls>"]
  }],
  "minimum_chrome_version": "114",
  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
