{
  "manifest_version": 3,
  "name": "GuardianCore Client",
  "version": "0.1.0",
  "description": "Proof-of-concept client plugin for GuardianCore.",
  "action": { 
    "default_popup": "popup.html", 
    "default_title": "GuardianCore",
    "default_icon": {
      "16": "icons/icon.svg",
      "32": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    }
  },
  "background": { "service_worker": "background.js" },
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:8000/*"],
  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
