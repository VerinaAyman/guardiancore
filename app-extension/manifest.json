{
  "manifest_version": 3,
  "name": "GuardianCore Client",
  "version": "0.1.0",
  "description": "Proof-of-concept client plugin for GuardianCore.",
  "action": { "default_popup": "popup.html", "default_title": "GuardianCore" },
  "background": { "service_worker": "background.js" },
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:8000/*"]
}
