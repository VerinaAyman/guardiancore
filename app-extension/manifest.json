{
  "manifest_version": 3,
  "name": "GuardianCore",
  "version": "0.4.4",
  "description": "Fixed database schema, streak tracking, and add rule",
  "permissions": ["webRequest", "webNavigation", "storage", "tabs", "downloads"],
  "host_permissions": ["<all_urls>"],
  "background": { 
    "service_worker": "background.js",
    "type": "module"
  },
  "action": { 
    "default_popup": "popup.html",
    "default_title": "GuardianCore"
  },
  "options_page": "options.html",
  "web_accessible_resources": [{
    "resources": ["blocked.html", "crypto.js", "strings.js"],
    "matches": ["<all_urls>"]
  }],
  "minimum_chrome_version": "114",
  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
