{
  "manifest_version": 3,
  "name": "GuardianCore Audit Probe",
  "version": "0.2.0",
  "description": "Privacy-focused audit probe for GuardianCore compliance monitoring.",
  "permissions": ["webRequest", "webNavigation", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": { 
    "default_popup": "popup.html",
    "default_title": "GuardianCore Settings"
  },
  "minimum_chrome_version": "114",
  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
