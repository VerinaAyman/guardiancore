{
  "manifest_version": 3,
  "name": "GuardianCore",
  "version": "0.3.0",
  "description": "Privacy-focused audit probe with parental controls and explainable enforcement.",
  "permissions": ["webRequest", "webNavigation", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": { 
    "default_popup": "popup.html",
    "default_title": "GuardianCore"
  },
  "options_page": "options.html",
  "web_accessible_resources": [{
    "resources": ["blocked.html"],
    "matches": ["<all_urls>"]
  }],
  "minimum_chrome_version": "114",
  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
